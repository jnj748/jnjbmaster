{
  "name": "work-log-standalone",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "관리소장 업무일지 / 주보 / 월보 단일 폴더 앱",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs server/index.ts",
