  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.12",
    "@types/express": "4.17.21",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vite": "6.0.5"
  }
}
